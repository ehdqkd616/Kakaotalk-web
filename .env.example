# ────────────────────────────────────────────────────
# KakaoTalk Web Client – 환경 변수 템플릿
# 이 파일을 복사해서 .env 를 만들어 실제 값을 입력하세요
# cp .env.example .env
# ────────────────────────────────────────────────────

# ── Kakao Developers 앱 설정 ──────────────────────────
# https://developers.kakao.com 에서 앱 생성 후 발급
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here
# 카카오 디벨로퍼스 > 앱 설정 > 카카오 로그인 > Redirect URI 에 동일하게 등록
KAKAO_REDIRECT_URI=http://localhost:4000/api/auth/kakao/callback

# ── 서버 ─────────────────────────────────────────────
PORT=4000
# 프로덕션에서는 반드시 랜덤 문자열로 변경하세요
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
NODE_ENV=development

# ── 클라이언트 ────────────────────────────────────────
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
